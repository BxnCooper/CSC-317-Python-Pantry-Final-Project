<DashboardScreen>:
    name: 'dashboard'
    BoxLayout:
        orientation: 'vertical'
        HeaderBar:
            Label:
                text: 'Python Pantry'
                color: app.text_color
                font_size: app.fs_lg
        BoxLayout:
            padding: dp(20)
            spacing: dp(12)
            StyledCard:
                Label:
                    text: 'Welcome to the dashboard'
                    font_size: app.fs_lg
            GridLayout:
                cols: 2
                size_hint_y: None
                height: dp(200)
                spacing: dp(12)
                StyledButton:
                    text: 'Inventory'
                    on_release: app.goto('inventory')
                StyledButton:
                    text: 'Donors'
                    on_release: app.goto('donor_management')
                StyledButton:
                    text: 'Client Portal'
                    on_release: app.goto('client_portal')
                StyledButton:
                    text: 'Volunteers'
                    on_release: app.goto('volunteer_portal')
            BoxLayout:
                size_hint_y: None
                height: dp(48)
                StyledButton:
                    text: 'Settings'
                    on_release: app.goto('settings')
                StyledButton:
                    text: 'Logout'
                    on_release: app.goto('login')
