#:kivy 1.0

<ConfirmScreen>:
    name: 'confirm'
    BoxLayout:
        orientation: 'vertical'
        # header
        HeaderBar:
            size_hint: (1, None)
            height: '50dp'
            Label:
                text: 'Confirm Data Deletion'
                font_size: app.fs_xl
                color: app.text_color
                bold: True
        # for spacing
        Label:
            text: ''
        # boxlayout for the text and button
        BoxLayout:
            orientation: 'vertical'
            size_hint: (1, None)
            height: '120dp'
            padding: dp(20)
            spacing: dp(10)
            Label:
                text: 'Are you sure you want to delete all user data?'
            Button:
                background_color: (0, 0, 0 ,0)
                background_normal: ''
                canvas.before:
                    Color:
                        rgba: 1, 0, 0, 1  # red
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [8]
                text: 'Reset User Data'
                on_release: root.reset_data()
        # for spacing
        Label:
            text: ''
        # back button that sends user to the settings
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            StyledButton:
                text: 'Back'
                on_release: app.goto('settings')