#:kivy 1.0

<RegisterScreen>:
    name: 'register'
    BoxLayout:
        orientation: 'vertical'
        # header
        HeaderBar:
            size_hint: (1, None)
            height: '50dp'
            Label:
                text: 'Register'
                color: app.text_color
                font_size: app.fs_xl
                bold: True
        # boxlayout for the rest of the widgets 
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            spacing: dp(12)
            # styled card that houses the username and password textboxes
            StyledCard:
                orientation: 'vertical'
                size_hint_y: None
                height: dp(120)
                BoxLayout:
                    size_hint_y: None
                    height: dp(40)
                    spacing: dp(8)
                    TextInput:
                        id: user
                        hint_text: 'username'
                    TextInput:
                        id: pwd
                        hint_text: 'password'
            # boxlayout for the create and back buttons
            BoxLayout:
                size_hint_y: None
                height: dp(48)
                spacing: dp(8)
                StyledButton:
                    text: 'Create'
                    on_release: root.do_register(user.text, pwd.text)
                StyledButton:
                    text: 'Back'
                    on_release: app.goto('login')
