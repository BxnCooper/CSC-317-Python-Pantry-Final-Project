<InventoryScreen>:
    name: 'inventory'
    BoxLayout:
        orientation: 'vertical'
        HeaderBar:
            Label:
                text: 'Inventory'
                color: app.text_color
                font_size: app.fs_lg
        ScrollView:
            do_scroll_x: False
            GridLayout:
                id: inv_list
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
        BoxLayout:
            size_hint_y: None
            height: dp(48)
            StyledButton:
                text: 'Refresh'
                on_release: root.refresh()
            StyledButton:
                text: 'Back'
                on_release: app.goto('dashboard')
