#:kivy 1.0

<ClientPortalScreen>:
    name: 'client_portal'

    BoxLayout:
        orientation: 'vertical'

        # ── Header bar shown at the top of every screen ──────────────
        HeaderBar:
            size_hint: (1, None)
            height: '56dp'
            Label:
                text: 'Client Portal'
                color: app.text_color
                font_size: app.fs_xl
                bold: True

        # ── Scrollable body so content works on small screens ─────────
        ScrollView:
            do_scroll_x: False

            BoxLayout:
                orientation: 'vertical'
                padding: dp(20)
                spacing: dp(16)
                size_hint_y: None
                height: self.minimum_height

                # ── Section 1: Register a new client account ──────────
                StyledBackgroundCard:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: dp(12)
                    spacing: dp(10)

                    Label:
                        text: 'Select Items'
                        color: app.text_color
                        font_size: app.fs_lg
                        bold: True
                        size_hint_y: None
                        height: dp(36)
                    
                    # gridlayout view called inv_list_client that displays all of the inventory items below 25 stock
                    GridLayout:
                        id: inv_list_client
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(8)

                    BoxLayout:
                        size_hint: (1, None)
                        height: '40dp'
                        Label:
                            id: inv_stat_txt
                            text: ''
                            font_size: app.fs_md
                            color: app.text_color

                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint: (1, None)
                        height: '50dp'
                        spacing: dp(10)
                        StyledButton:
                            text: 'Order Item'
                            on_press: root.order()
                        TextInput:
                            id: order_name
                            hint_text: "Enter Item Name"
                            size_hint: (1, None)
                            height: '40dp'
                        TextInput:
                            id: order_amount
                            hint_text: "Enter Amount"
                            size_hint: (1, None)
                            height: '40dp'

                        

                # ── Section 2: Dietary restriction / allergen tracking ─
                StyledBackgroundCard:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: self.minimum_height
                    padding: dp(12)
                    spacing: dp(8)

                    Label:
                        text: 'Dietary Restrictions'
                        color: app.text_color
                        font_size: app.fs_lg
                        bold: True
                        size_hint_y: None
                        height: dp(36)

                    Label:
                        text: 'Select any allergens that apply to the current client:'
                        color: app.text_color
                        font_size: app.fs_sm
                        size_hint_y: None
                        height: dp(28)

                    # allergen checkboxes are built dynamically in build_allergen_checkboxes()
                    # this container gets populated when the screen is entered
                    GridLayout:
                        id: allergen_list
                        cols: 1
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: dp(4)

                    # status label shows save confirmation or error
                    Label:
                        id: allergen_status
                        text: ''
                        color: app.accent
                        font_size: app.fs_sm
                        size_hint_y: None
                        height: dp(28)

                    # triggers save_allergens() in the screen class
                    StyledButton:
                        text: 'Save Allergens'
                        size_hint_y: None
                        height: dp(44)
                        on_release: root.save_allergens()

                # ── Navigation ────────────────────────────────────────
                BoxLayout:
                    size_hint_y: None
                    height: dp(48)
                    spacing: dp(8)

                    StyledButton:
                        text: 'Back'
                        on_release: root.back()