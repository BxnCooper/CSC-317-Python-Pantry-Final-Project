#:kivy 1.0

<LoginScreen>:
    name: 'login'
    BoxLayout:
        orientation: 'vertical'
        # header
        HeaderBar:
            size_hint: (1, None)
            height: '50dp'
            Label:
                text: 'Python Pantry'
                color: app.text_color
                font_size: app.fs_xl
                bold: True
        # boxlayout for the other login screen widgets
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            spacing: dp(12)
            # styledcard for the welcome back text
            StyledCard:
                Label:
                    text: 'Welcome back to the Python Pantry!'
                    font_size: app.fs_lg
                    color: app.text_color
            # boxlayout for the username and password textboxes
            BoxLayout:
                size_hint_y: None
                height: dp(40)
                TextInput:
                    id: user
                    hint_text: 'username'
                TextInput:
                    id: pwd
                    hint_text: 'password'
            # buttons for the login function and register screen
            StyledButton:
                text: 'Login'
                on_release: root.do_login(user.text, pwd.text)
            StyledButton:
                text: 'Register'
                on_release: app.goto('register')
