#:kivy 1.0
#:import dp kivy.metrics.dp

<StyledButton@Button>:
    size_hint_y: None
    height: dp(40)
    background_normal: ''
    background_color: (0,0,0,0)
    canvas.before:
        Color:
            rgba: app.primary if hasattr(app, 'primary') else (0.06,0.53,0.86,1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [8]
    color: app.text_color if hasattr(app, 'text_color') else (1,1,1,1)
    font_size: app.fs_md if hasattr(app, 'fs_md') else dp(16)
